# === YouTube Factory — Audio Endpoint (slim CI/CD layer) ===
# Base image contains: ComfyUI + custom nodes + models + all deps
# This layer only adds: handler code + startup script
# Build time: ~2 min (vs ~40 min with full Dockerfile)

FROM ghcr.io/peperay/yt-factory-audio-base:v1

# ── Handler code (changes frequently) ──
COPY r2_helper.py /r2_helper.py
COPY handler_audio.py /handler.py
COPY start_audio.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
