# === YouTube Factory — Audio Base Image ===
# Contains: ComfyUI + custom nodes + ALL models + Python deps
# Rebuild only when models or core deps change
# CI/CD Dockerfile.audio does: FROM this + COPY handlers

ARG BASE_IMAGE=nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04

FROM ${BASE_IMAGE} AS base

ARG COMFYUI_VERSION=0.18.2

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_PREFER_BINARY=1
ENV PYTHONUNBUFFERED=1
ENV CMAKE_BUILD_PARALLEL_LEVEL=8

# System dependencies (same as proven monolithic)
RUN apt-get update && apt-get install -y \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    git \
    wget \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    ffmpeg \
    libsndfile1 \
    build-essential \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && apt-get autoremove -y && apt-get clean -y && rm -rf /var/lib/apt/lists/*

# Install uv + venv
RUN wget -qO- https://astral.sh/uv/install.sh | sh \
    && ln -s /root/.local/bin/uv /usr/local/bin/uv \
    && ln -s /root/.local/bin/uvx /usr/local/bin/uvx \
    && uv venv /opt/venv

ENV PATH="/opt/venv/bin:${PATH}"

# ── ComfyUI Core ────────────────────────────────────────────
RUN uv pip install comfy-cli pip setuptools wheel

RUN /usr/bin/yes | comfy --workspace /comfyui install --version "${COMFYUI_VERSION}" --nvidia

RUN uv pip install --force-reinstall torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu126

WORKDIR /comfyui

RUN grep -v -i -E '^(torch==|torch>=|torch<=|torchvision==|torchvision>=|torchaudio==|torchaudio>=|nvidia)' requirements.txt > /tmp/reqs_no_torch.txt && \
    uv pip install -r /tmp/reqs_no_torch.txt && \
    rm /tmp/reqs_no_torch.txt

# ── Custom Nodes: AUDIO ONLY ────────────────────────────────
# From proven monolithic, minus image/video nodes (gguf, ltxvideo, detail-daemon, etc.)
# Each install separated to isolate failures
RUN comfy node install comfyui-whisper || true
RUN comfy node install comfyui-kjnodes || true
RUN comfy node install comfyui-custom-scripts || true

# VHS (VHS_LoadAudio needed for voice-srt) — git clone is more reliable than comfy node install
RUN cd /comfyui/custom_nodes \
    && rm -rf ComfyUI-VideoHelperSuite 2>/dev/null || true \
    && git clone https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite.git \
    && cd ComfyUI-VideoHelperSuite \
    && (pip install -r requirements.txt 2>/dev/null || true) \
    && echo "=== VHS installed via git clone ==="

# VibeVoice + TTS-Audio-Suite — baked in image (no NV fallback)
# Retry logic: GitHub Actions runners sometimes hit transient network issues
# cloning from GitHub. Shallow clone (--depth 1) reduces payload size.
RUN cd /comfyui/custom_nodes \
    && for attempt in 1 2 3; do \
         echo "=== VibeVoice clone attempt $attempt/3 ===" \
         && git clone --depth 1 --recursive https://github.com/DualOrion/VibeVoice-ComfyUI.git \
         && break \
         || { echo "WARN: VibeVoice clone attempt $attempt failed"; [ $attempt -lt 3 ] && sleep 5; }; \
       done \
    && test -d VibeVoice-ComfyUI \
    && cd VibeVoice-ComfyUI \
    && if [ -f requirements.txt ]; then \
         grep -v -i -E '^(torch==|torch>=|torchvision|torchaudio|nvidia)' requirements.txt > /tmp/vv_reqs.txt \
         && uv pip install -r /tmp/vv_reqs.txt && rm /tmp/vv_reqs.txt; \
       fi \
    && echo "=== VibeVoice-ComfyUI installed ==="

RUN cd /comfyui/custom_nodes \
    && for attempt in 1 2 3; do \
         echo "=== TTS-Audio-Suite clone attempt $attempt/3 ===" \
         && git clone --depth 1 --recursive https://github.com/DualOrion/TTS-Audio-Suite.git \
         && break \
         || { echo "WARN: TTS-Audio-Suite clone attempt $attempt failed"; [ $attempt -lt 3 ] && sleep 5; }; \
       done \
    && test -d TTS-Audio-Suite \
    && cd TTS-Audio-Suite \
    && if [ -f requirements.txt ]; then \
         grep -v -i -E '^(torch==|torch>=|torchvision|torchaudio|nvidia)' requirements.txt > /tmp/tts_reqs.txt \
         && uv pip install -r /tmp/tts_reqs.txt && rm /tmp/tts_reqs.txt; \
       fi \
    && echo "=== TTS-Audio-Suite installed ==="

WORKDIR /

# ── Audio/ML dependencies (IDENTICAL to proven monolithic) ──
RUN uv pip install --no-cache-dir \
    "transformers>=4.51.3,<5.0" \
    accelerate \
    diffusers \
    peft \
    datasets \
    scipy \
    librosa \
    soundfile \
    sounddevice \
    av \
    aiortc \
    bitsandbytes \
    ml-collections \
    absl-py \
    omegaconf \
    dacite \
    conformer \
    x-transformers \
    torchdiffeq \
    ema-pytorch \
    vocos \
    echo-tts \
    monotonic-alignment-search \
    && echo "=== Audio/ML deps installed ==="

# TTS-Audio-Suite specific deps (IDENTICAL to proven monolithic)
RUN uv pip install --no-cache-dir \
    jieba \
    pypinyin \
    unidecode \
    phonemizer \
    cn2an \
    g2p-en \
    inflect \
    sentencepiece \
    textstat \
    punctuators \
    funasr \
    nagisa \
    hyperpyyaml \
    modelscope \
    munch \
    json5 \
    faiss-cpu \
    praat-parselmouth \
    pyworld \
    torchfcpe \
    wandb \
    keras \
    openai-whisper \
    && echo "=== TTS deps installed ==="

# ── Restore critical packages ───────────────────────────────
RUN uv pip install --force-reinstall --no-cache-dir \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu126 \
    && uv pip install --force-reinstall --no-cache-dir numpy \
    && echo "=== PyTorch + numpy restored ==="

RUN cd /comfyui \
    && grep -v -i -E '^(torch==|torch>=|torch<=|torchvision|torchaudio|nvidia)' requirements.txt \
       > /tmp/comfy_reqs_final.txt \
    && uv pip install --no-cache-dir -r /tmp/comfy_reqs_final.txt \
    && rm /tmp/comfy_reqs_final.txt \
    && echo "=== ComfyUI deps restored ==="

RUN uv pip install --no-cache-dir comfy-aimdo torchsde comfyui-frontend-package comfy-kitchen blake3 simpleeval \
    sqlalchemy alembic kornia \
    && echo "=== explicit runtime deps installed ==="

# ── Handler runtime deps (needed by handler.py at runtime) ──
RUN uv pip install --no-cache-dir runpod requests websocket-client boto3

# ── Install huggingface_hub CLI for model downloads ─────────
RUN uv pip install --no-cache-dir "huggingface_hub[cli]"

# ── Model directory structure ───────────────────────────────
RUN mkdir -p /comfyui/models/{vibevoice,TTS,stt,audio_encoders,model_patches}

# ── Download models (HEAVY — cached in base image) ─────────
# VibeVoice-Large (~18.5 GB)
RUN huggingface-cli download microsoft/VibeVoice-Large \
    --local-dir /comfyui/models/vibevoice/VibeVoice-Large

# Whisper large-v3 (~3 GB)
RUN huggingface-cli download openai/whisper-large-v3 \
    --local-dir /comfyui/models/stt/whisper/large-v3

# ── Verify environment (build-time gate) ────────────────────
# If any import or model check fails, the build fails — no broken images pushed.
RUN python -c "\
import os; \
import torch; \
import torchaudio; \
import numpy; \
import comfy_aimdo; \
import torchsde; \
import alembic; \
import sqlalchemy; \
import kornia; \
import av; \
import PIL; \
import transformers; \
import pydantic; \
import blake3; \
from packaging.version import Version; \
assert Version(transformers.__version__) >= Version('4.51.3'), f'transformers {transformers.__version__} < 4.51.3 (VibeVoice requires >=4.51.3)'; \
assert os.path.isdir('/comfyui/custom_nodes/ComfyUI-VideoHelperSuite'), 'VHS not installed — VHS_LoadAudio will fail'; \
assert os.path.isfile('/comfyui/custom_nodes/ComfyUI-VideoHelperSuite/__init__.py'), 'VHS __init__.py missing'; \
assert os.path.isdir('/comfyui/custom_nodes/VibeVoice-ComfyUI'), 'VibeVoice-ComfyUI not baked — txt-voice will fail'; \
assert os.path.isdir('/comfyui/custom_nodes/TTS-Audio-Suite'), 'TTS-Audio-Suite not baked — txt-voice will fail'; \
assert os.path.isdir('/comfyui/models/vibevoice/VibeVoice-Large'), 'VibeVoice-Large model not downloaded'; \
assert os.path.isdir('/comfyui/models/stt/whisper/large-v3'), 'Whisper large-v3 model not downloaded'; \
print(f'torch={torch.__version__}, numpy={numpy.__version__}, transformers={transformers.__version__}'); \
print('=== VibeVoice-Large model verified ==='); \
print('=== Whisper large-v3 model verified ==='); \
print('=== Audio base image environment verified ===')"

ENV RUNPOD_NETWORK_VOLUME_PATH="/runpod-volume"

LABEL description="YT Factory Audio base — ComfyUI + models + deps"
LABEL version="v1"
