# ============================================================
# YouTube Factory — Audio Endpoint (VibeVoice TTS + Whisper STT)
# Job types: txt-voice, voice-srt
# Based on: proven monolithic Dockerfile (bf1e0f3, 18 iterations)
# ============================================================

ARG BASE_IMAGE=nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04

FROM ${BASE_IMAGE} AS base

ARG COMFYUI_VERSION=latest

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_PREFER_BINARY=1
ENV PYTHONUNBUFFERED=1
ENV CMAKE_BUILD_PARALLEL_LEVEL=8

# System dependencies (same as proven monolithic)
RUN apt-get update && apt-get install -y \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    git \
    wget \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    ffmpeg \
    libsndfile1 \
    build-essential \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && apt-get autoremove -y && apt-get clean -y && rm -rf /var/lib/apt/lists/*

# Install uv + venv
RUN wget -qO- https://astral.sh/uv/install.sh | sh \
    && ln -s /root/.local/bin/uv /usr/local/bin/uv \
    && ln -s /root/.local/bin/uvx /usr/local/bin/uvx \
    && uv venv /opt/venv

ENV PATH="/opt/venv/bin:${PATH}"

# ── ComfyUI Core ────────────────────────────────────────────
RUN uv pip install comfy-cli pip setuptools wheel

RUN /usr/bin/yes | comfy --workspace /comfyui install --version "${COMFYUI_VERSION}" --nvidia

RUN uv pip install --force-reinstall torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu126

WORKDIR /comfyui

RUN grep -v -i -E '^(torch==|torch>=|torch<=|torchvision==|torchvision>=|torchaudio==|torchaudio>=|nvidia)' requirements.txt > /tmp/reqs_no_torch.txt && \
    uv pip install -r /tmp/reqs_no_torch.txt && \
    rm /tmp/reqs_no_torch.txt

# ── Model paths: Network Volume ─────────────────────────────
COPY extra_model_paths.yaml ./

# ── Custom Nodes: AUDIO ONLY ────────────────────────────────
# From proven monolithic, minus image/video nodes (gguf, ltxvideo, detail-daemon, etc.)
RUN comfy node install comfyui-whisper || true && \
    comfy node install comfyui-videohelpersuite || true && \
    comfy node install comfyui-kjnodes || true && \
    comfy node install comfyui-custom-scripts || true

# VibeVoice + TTS-Audio-Suite (from git — same as proven monolithic)
RUN cd custom_nodes \
    && (git clone https://github.com/DualOrion/VibeVoice-ComfyUI.git \
        && cd VibeVoice-ComfyUI && pip install -r requirements.txt 2>/dev/null \
        || echo "WARN: VibeVoice clone failed — will link from Network Volume") \
    ; cd /comfyui/custom_nodes \
    && (git clone https://github.com/DualOrion/TTS-Audio-Suite.git \
        && cd TTS-Audio-Suite && pip install -r requirements.txt 2>/dev/null \
        || echo "WARN: TTS-Audio-Suite clone failed — will link from Network Volume")

WORKDIR /

# ── Audio/ML dependencies (IDENTICAL to proven monolithic) ──
RUN uv pip install \
    "transformers>=4.40,<5.0" \
    accelerate \
    diffusers \
    peft \
    datasets \
    scipy \
    librosa \
    soundfile \
    sounddevice \
    av \
    aiortc \
    bitsandbytes \
    ml-collections \
    absl-py \
    omegaconf \
    dacite \
    conformer \
    x-transformers \
    torchdiffeq \
    ema-pytorch \
    vocos \
    echo-tts \
    monotonic-alignment-search \
    && echo "=== Audio/ML deps installed ==="

# TTS-Audio-Suite specific deps (IDENTICAL to proven monolithic)
RUN uv pip install \
    jieba \
    pypinyin \
    unidecode \
    phonemizer \
    cn2an \
    g2p-en \
    inflect \
    sentencepiece \
    textstat \
    punctuators \
    funasr \
    nagisa \
    hyperpyyaml \
    modelscope \
    munch \
    json5 \
    faiss-cpu \
    praat-parselmouth \
    pyworld \
    torchfcpe \
    wandb \
    keras \
    openai-whisper \
    && echo "=== TTS deps installed ==="

# ── Restore critical packages ───────────────────────────────
RUN uv pip install --force-reinstall \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu126 \
    && uv pip install --force-reinstall numpy \
    && echo "=== PyTorch + numpy restored ==="

RUN cd /comfyui \
    && grep -v -i -E '^(torch==|torch>=|torch<=|torchvision|torchaudio|nvidia)' requirements.txt \
       > /tmp/comfy_reqs_final.txt \
    && uv pip install -r /tmp/comfy_reqs_final.txt \
    && rm /tmp/comfy_reqs_final.txt \
    && echo "=== ComfyUI deps restored ==="

RUN uv pip install comfy-aimdo torchsde comfyui-frontend-package comfy-kitchen blake3 simpleeval \
    sqlalchemy alembic kornia \
    && echo "=== explicit runtime deps installed ==="

# ── Verify environment (build-time gate) ────────────────────
# If any import fails, the build fails — no broken images pushed.
RUN python -c "\
import torch; \
import torchaudio; \
import numpy; \
import comfy_aimdo; \
import torchsde; \
import alembic; \
import sqlalchemy; \
import kornia; \
import av; \
import PIL; \
import transformers; \
import pydantic; \
import blake3; \
print(f'torch={torch.__version__}, numpy={numpy.__version__}'); \
print('=== Audio endpoint environment verified ===')"

# ── Handler ──────────────────────────────────────────────────
RUN uv pip install runpod requests websocket-client

COPY handler_audio.py /handler.py
COPY start_audio.sh /start.sh
RUN chmod +x /start.sh

ENV RUNPOD_NETWORK_VOLUME_PATH="/runpod-volume"

CMD ["/start.sh"]
