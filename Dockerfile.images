# ============================================================
# YouTube Factory — Images Endpoint (Flux 2 Klein + LoRAs)
# Job types: txt-img
# Optimized: Only image generation nodes from TXT-IMG_API workflow
#
# 2026-04-23: Models baked into image (NV-free operation). Previously
# assumed Network Volume; endpoint actually has networkVolumeId="" so
# the monolithic image must be self-sufficient. See lesson #48 follow-up
# in rules/runpod-infrastructure.md.
# ============================================================

ARG BASE_IMAGE=nvidia/cuda:12.6.3-cudnn-runtime-ubuntu24.04

FROM ${BASE_IMAGE} AS base

ARG COMFYUI_VERSION=0.18.2
ARG HF_TOKEN
ENV HF_TOKEN=${HF_TOKEN}

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_PREFER_BINARY=1
ENV PYTHONUNBUFFERED=1
ENV CMAKE_BUILD_PARALLEL_LEVEL=8

# System dependencies
RUN apt-get update && apt-get install -y \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    git \
    wget \
    libgl1 \
    libglib2.0-0 \
    ffmpeg \
    imagemagick \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && apt-get autoremove -y && apt-get clean -y && rm -rf /var/lib/apt/lists/*

# Install uv + venv
RUN wget -qO- https://astral.sh/uv/install.sh | sh \
    && ln -s /root/.local/bin/uv /usr/local/bin/uv \
    && ln -s /root/.local/bin/uvx /usr/local/bin/uvx \
    && uv venv /opt/venv

ENV PATH="/opt/venv/bin:${PATH}"

# ── ComfyUI Core ────────────────────────────────────────────
RUN uv pip install comfy-cli pip setuptools wheel

# Pin torch BEFORE comfy install. PyTorch 2.10.0+ (released 2026-04-23)
# adds nvidia-nvtx-cu12==12.6.77 constraint that breaks pip's resolver
# against ComfyUI 0.18.2's ecosystem. 2.9.1 is the last version that
# resolves cleanly. Pre-installing it means comfy-cli sees torch already
# satisfied and doesn't try to upgrade.
RUN uv pip install \
    torch==2.9.1+cu126 \
    torchvision==0.24.1+cu126 \
    torchaudio==2.9.1+cu126 \
    --index-url https://download.pytorch.org/whl/cu126

RUN /usr/bin/yes | comfy --workspace /comfyui install --version "${COMFYUI_VERSION}" --nvidia

RUN uv pip install --force-reinstall \
    torch==2.9.1+cu126 \
    torchvision==0.24.1+cu126 \
    torchaudio==2.9.1+cu126 \
    --index-url https://download.pytorch.org/whl/cu126

WORKDIR /comfyui

RUN grep -v -i -E '^(torch==|torch>=|torch<=|torchvision==|torchvision>=|torchaudio==|torchaudio>=|nvidia)' requirements.txt > /tmp/reqs_no_torch.txt && \
    uv pip install -r /tmp/reqs_no_torch.txt && \
    rm /tmp/reqs_no_torch.txt

# ── Model paths config ──────────────────────────────────────
COPY extra_model_paths.yaml ./

# ── Custom Nodes: IMAGE ONLY ────────────────────────────────
# Only what TXT-IMG_API workflow uses:
#   UnetLoaderGGUF → comfyui-gguf
#   DetailDaemonSamplerNode → comfyui-detail-daemon
#   Power Lora Loader → rgthree-comfy
RUN comfy node install comfyui-gguf || true && \
    comfy node install comfyui-detail-daemon || true && \
    comfy node install rgthree-comfy || true

WORKDIR /

# ── Fonts for thumbnail text overlay ─────────────────────────
RUN mkdir -p /usr/local/share/fonts/bebas-neue \
    && wget -q "https://github.com/google/fonts/raw/main/ofl/bebasneue/BebasNeue-Regular.ttf" \
       -O /usr/local/share/fonts/bebas-neue/BebasNeue-Regular.ttf \
    && fc-cache -f \
    && echo "=== Bebas Neue font installed ==="

# ── Image-specific deps ─────────────────────────────────────
RUN uv pip install \
    opencv-python \
    gguf \
    && echo "=== Image deps installed ==="

# ── Restore critical packages ───────────────────────────────
# Keep the same 2.9.1 pin here (pre-2.10 regression, see ComfyUI Core note above).
RUN uv pip install --force-reinstall \
    torch==2.9.1+cu126 \
    torchvision==0.24.1+cu126 \
    torchaudio==2.9.1+cu126 \
    --index-url https://download.pytorch.org/whl/cu126 \
    && uv pip install --force-reinstall numpy \
    && echo "=== PyTorch + numpy restored ==="

RUN cd /comfyui \
    && grep -v -i -E '^(torch==|torch>=|torch<=|torchvision|torchaudio|nvidia)' requirements.txt \
       > /tmp/comfy_reqs_final.txt \
    && uv pip install -r /tmp/comfy_reqs_final.txt \
    && rm /tmp/comfy_reqs_final.txt \
    && echo "=== ComfyUI deps restored ==="

RUN uv pip install comfy-aimdo torchsde comfyui-frontend-package comfy-kitchen blake3 simpleeval \
    sqlalchemy alembic kornia safetensors einops transformers tokenizers sentencepiece scipy tqdm av filelock matplotlib spandrel \
    && echo "=== explicit runtime deps installed ==="

# ── Verify environment (build-time gate) ────────────────────
# If any import fails, the build fails — no broken images pushed.
RUN python -c "\
import torch; \
import torchvision; \
import numpy; \
import safetensors; \
import comfy_aimdo; \
import sqlalchemy; \
import alembic; \
import kornia; \
import PIL; \
import gguf; \
import blake3; \
import einops; \
import transformers; \
import matplotlib; \
import spandrel; \
print(f'torch={torch.__version__}, numpy={numpy.__version__}, transformers={transformers.__version__}'); \
print('=== Images endpoint environment verified ===')"

# ── Model directories ───────────────────────────────────────
RUN mkdir -p /comfyui/models/diffusion_models \
             /comfyui/models/vae \
             /comfyui/models/clip \
             /comfyui/models/loras \
             /comfyui/models/text_encoders \
             /comfyui/models/unet \
             /comfyui/models/checkpoints \
             /comfyui/models/controlnet \
             /comfyui/models/upscale_models \
             /comfyui/models/embeddings

# ── Model Downloads (baked in for NV-free operation) ────────
# Flux 2 Klein GGUF Q8 (~10 GB) — public, UnetLoaderGGUF
RUN wget -q --show-progress -O /comfyui/models/diffusion_models/flux-2-klein-9b-Q8_0.gguf \
    "https://huggingface.co/unsloth/FLUX.2-klein-9B-GGUF/resolve/main/flux-2-klein-9b-Q8_0.gguf"

# Flux 2 Klein fp8 (~9.4 GB) — gated, requires HF_TOKEN, UNETLoader
RUN wget -q --show-progress -O /comfyui/models/diffusion_models/flux-2-klein-9b-fp8.safetensors \
    --header="Authorization: Bearer ${HF_TOKEN}" \
    "https://huggingface.co/black-forest-labs/FLUX.2-klein-9b-fp8/resolve/main/flux-2-klein-9b-fp8.safetensors"

# Flux 2 VAE (~336 MB) — public, VAELoader
RUN wget -q --show-progress -O /comfyui/models/vae/flux2-vae.safetensors \
    "https://huggingface.co/Comfy-Org/flux2-dev/resolve/main/split_files/vae/flux2-vae.safetensors"

# Qwen 3 8B fp8 abliterated text encoder (~8.2 GB) — public, CLIPLoader
RUN wget -q --show-progress -O /comfyui/models/clip/qwen_3_8b_fp8mixed_abliterated.safetensors \
    "https://huggingface.co/edicamargo/qwen_3_8b_fp8mixed_abliterated/resolve/main/qwen_3_8b_fp8mixed_abliterated.safetensors"

# ── Verify core models exist (build-time gate) ──────────────
# If any model download failed silently, fail the build here — never push
# an image that will silently fail at runtime with "Value not in list" errors.
RUN echo "=== Verifying model files ===" && \
    test -s /comfyui/models/diffusion_models/flux-2-klein-9b-Q8_0.gguf && \
    test -s /comfyui/models/diffusion_models/flux-2-klein-9b-fp8.safetensors && \
    test -s /comfyui/models/vae/flux2-vae.safetensors && \
    test -s /comfyui/models/clip/qwen_3_8b_fp8mixed_abliterated.safetensors && \
    ls -lh /comfyui/models/diffusion_models/ /comfyui/models/vae/ /comfyui/models/clip/ && \
    echo "=== All core models verified ===" || \
    (echo "ERROR: Missing or empty model files!" && exit 1)

# ── Clear HF token (don't bake into final image) ────────────
ENV HF_TOKEN=

# ── Handler ──────────────────────────────────────────────────
RUN uv pip install runpod requests websocket-client boto3

COPY r2_helper.py /r2_helper.py
COPY handler_images.py /handler.py
COPY start_images.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
