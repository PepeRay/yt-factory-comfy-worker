# === YouTube Factory — Images Endpoint (slim CI/CD layer) ===
# Base image contains: ComfyUI + custom nodes + models + all deps
# This layer only adds: handler code + startup script
# Build time: ~2 min (vs ~35 min with full Dockerfile)

FROM ghcr.io/peperay/yt-factory-images-base:v1

# ── Handler code (changes frequently) ──
COPY r2_helper.py /r2_helper.py
COPY handler_images.py /handler.py
COPY start_images.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
